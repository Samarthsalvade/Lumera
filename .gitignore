# ── Secrets ──────────────────────────────────────────
.env
backend/.env

# ── Database (replaced by Neon) ──────────────────────
backend/instance/
*.db

# ── Uploaded images (replaced by Cloudinary) ─────────
backend/uploads/

# ── Python virtual environment ────────────────────────
venv/
backend/venv/
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd

# ── ML models (tracked via Git LFS — do NOT ignore) ───
# *.keras and *.h5 are committed through Git LFS
# Only ignore tflite files (not used in production)
*.tflite
backend/services/*.tflite

# ── JSON class index files (small, safe to include) ───
# (these are NOT ignored — they're needed for inference)

# ── Training data (gigabytes, not needed) ─────────────
backend/dataset_downloads/
backend/training_data/
backend/concern_training_data/
backend/concern_training_data_v2/
backend/concern_training_data_v3/

# ── Node modules ──────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.env.local
frontend/.env*.local

# ── OS / editor junk ──────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ── Misc backend junk ─────────────────────────────────
backend/ml_model/*.h5.bak
backend/ml_model/*.png
backend/ml_model/audit_suspects.txt
backend/test_uploads/
backend/acne
backend/darkcircle
backend/wrinkles
*/__pycache__/
**/__pycache__/
*.png