{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/send-email.cjs": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    {
      "src": "/api/send-email",
      "dest": "/api/send-email.cjs"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}